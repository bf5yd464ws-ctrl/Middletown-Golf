  "newsletters": [
    {
      "id": "april",
      "month": "April",
      "label": "April 2025",
      "content": "The 2025 season is underway! Membership is open to all golfers. Contact Russ Yenser at 513-571-7931 for more information. This year prizes will again be awarded for accumulated totals in Money Winners, Net Points, and Side Games. The last 3 tournaments will be double points. Entry fees have increased slightly this year. Application fee is $25. Mail entries to: Russ Yenser, 503 Cranewood Drive, Trenton, Ohio 45067."
    },
    {
      "id": "may",
      "month": "May",
      "label": "May 2025",
      "content": "May featured our annual double-header weekend at Shaker Run and Yankee Trace. The Shaker Run format this year was 3-Man with Single Ball on Par 5s, Double Ball on Par 4s, and Triple Ball on Par 3s. At Yankee Trace we played a 2-Man Customized Stableford format."
    },
    {
      "id": "june",
      "month": "June",
      "label": "June 2025",
      "content": "The June tournament at Walden Ponds featured our 4-Man Triple Best Ball format. A great day of team golf with five foursomes competing."
    },
    {
      "id": "august",
      "month": "August",
      "label": "August 2025",
      "content": "The Heatherwoode tournament ran our 3-Man Double Best Ball format. Steve Goertemiller had an outstanding day shooting a net 67 for the Individual Low Net title."
    },
    {
      "id": "september",
      "month": "September",
      "label": "September 2025",
      "content": "Only 8 golfers turned out for the Cassel Hills event this year. Russ Yenser and Roger Campbell won the team competition with a 64. The smaller field made for a quick round but competitive play."
    },
    {
      "id": "october",
      "month": "October",
      "label": "October 2025",
      "content": "The season concluded at Wildwood Golf Club with 16 golfers. Jeff Zimmer and David Simpson took top honors at 67. A reminder for next year: entries are due 10 days in advance (14 days for Heatherwoode). Golfers who back out after paying will forfeit $20 of their entry fee. Please finish all holes — net points depend on complete scores."
    },
    {
      "id": "yearend",
      "month": "Year End",
      "label": "Year End 2025",
      "content": "The 2025 season is complete. Year-end bonus payouts at Wildwood: Side Money — Goertemiller $60, Holmes $40, Saniga $20. Net Points — Holmes $60, Simpson $40, Conway $20. Money Leaders — Goertemiller $60, Simpson $40. Changes for 2026: scorecards will be traded between teams, and all holes must be played out — players who do not finish holes may be disqualified. Tournament fees will increase slightly in 2026 due to rising golf costs. Hope to see everyone back and bring a friend!"
    }
  ]
